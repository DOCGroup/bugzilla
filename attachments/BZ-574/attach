// IDL
module Test
{
   struct Tstruct
   {
      short ShortSElem;
      long LongSElem;
   };

   typedef sequence<Tstruct> TstructSeq;

   union Tunion switch (short)
   {
      case 1: short ShortUElem;
      case 2: Tstruct StructUElem;
      case 3: TstructSeq SeqUElem;
   };

   interface Server
   {
      void PushAny(in Any data);
      void Shutdown();
   };
};


