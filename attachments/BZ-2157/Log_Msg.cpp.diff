+/// Default is to append usecs to date_time string.
+int ACE_Log_Msg::append_usecs_ = 1;
+/// Default is not to append UTC value to date_time string.
+int ACE_Log_Msg::append_utc_ = 0;
+/// Date/timestamp format
+ACE_TCHAR ACE_Log_Msg::date_time_fmt_[ACE_MAXLOGDATETIME + 1]="%a %b %d %Y %H:%M:%S";
