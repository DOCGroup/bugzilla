+ACE_TCHAR ACE_Log_Msg::utc_separator_='|';
+
+void
+ACE_Log_Msg::date_time_format (ACE_TCHAR date_time_fmt[],
+                               int append_usecs,
+                               int append_utc,
+                               char utc_separator)
+{
+  ACE_TRACE ("ACE_Log_Msg::date_time_format");
+  ACE_MT (ACE_GUARD (ACE_Recursive_Thread_Mutex, ace_mon,
+                     *ACE_Log_Msg_Manager::get_lock ()));
+  ACE_OS::strncpy(ACE_Log_Msg::date_time_fmt_,date_time_fmt,ACE_MAXLOGDATETIME);
+  ACE_Log_Msg::date_time_fmt_[ACE_MAXLOGDATETIME] = '\0';
+  ACE_Log_Msg::append_usecs_ = append_usecs;
+  ACE_Log_Msg::append_utc_ = append_utc;
+  ACE_Log_Msg::utc_separator_ = utc_separator;
+}
+
+int
+ACE_Log_Msg::append_usecs (void)
+{
+  ACE_TRACE ("ACE_Log_Msg::append_usecs");
+  int result;
+  ACE_MT (ACE_GUARD_RETURN (ACE_Recursive_Thread_Mutex, ace_mon,
+                            *ACE_Log_Msg_Manager::get_lock (), 0));
+
+  result = ACE_Log_Msg::append_usecs_;
+  return result;
+}
+
+int
+ACE_Log_Msg::append_utc (void)
+{
+  ACE_TRACE ("ACE_Log_Msg::append_utc");
+  int result;
+  ACE_MT (ACE_GUARD_RETURN (ACE_Recursive_Thread_Mutex, ace_mon,
+                            *ACE_Log_Msg_Manager::get_lock (), 0));
+
+  result = ACE_Log_Msg::append_utc_;
+  return result;
+}
+
+const ACE_TCHAR *
+ACE_Log_Msg::date_time_fmt (void)
+{
+  ACE_TRACE ("ACE_Log_Msg::append_utc");
+  ACE_TCHAR *result;
+  ACE_MT (ACE_GUARD_RETURN (ACE_Recursive_Thread_Mutex, ace_mon,
+                            *ACE_Log_Msg_Manager::get_lock (), 0));
+
+  result = ACE_Log_Msg::date_time_fmt_;
+  return result;
+}
+
+ACE_TCHAR
+ACE_Log_Msg::utc_separator (void)
+{
+  ACE_TRACE ("ACE_Log_Msg::utc_separator");
+  ACE_TCHAR result;
+  ACE_MT (ACE_GUARD_RETURN (ACE_Recursive_Thread_Mutex, ace_mon,
+                            *ACE_Log_Msg_Manager::get_lock (), 0));
+
+  result = ACE_Log_Msg::utc_separator_;
+  return result;
