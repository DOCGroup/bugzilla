+ 
+ void
+ ACE_Event_Handler::add_ref (ACE_Event_Handler* h)
+ {
+   if (h != 0)
+     {
+       int r;
+       {
+         ACE_GUARD (ACE_SYNCH_MUTEX, guard, h->ref_count_mutex_);
+         r = ++h->ref_count_;
+       }
+     }
+ 
+ }
+ 
+ void 
+ ACE_Event_Handler::remove_ref (ACE_Event_Handler* h)
+ {
+   if (h != 0)
+     {
+       int r;
+       {
+         ACE_GUARD (ACE_SYNCH_MUTEX, guard, h->ref_count_mutex_);
+         r = --h->ref_count_;
+       }
+       if (r == 0)
+       {
+         delete h;
+       }
+     }
  }
  
  void
  ACE_Event_Handler::reactor (ACE_Reactor *reactor)
  {
    ACE_TRACE ("ACE_Event_Handler::reactor");
    this->reactor_ = reactor;
  }
  
