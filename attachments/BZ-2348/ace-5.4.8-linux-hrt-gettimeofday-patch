+int
+ACE_High_Res_Timer::calibrate_gtf_adjustment (
+	ACE_UINT32 hrt32,
+	const ACE_Time_Value& hrt_tv,
+	bool from_gft)
+{
+	if (ACE_High_Res_Timer::gtf_adjust_ ==
+		 ACE_High_Res_Timer::GTF_ADJUST_NOT_INITIALIZED // first time initialization
+		 ||
+		 ACE_High_Res_Timer::hrt_32hb_ > hrt32 // re-calibration on overflow
+		)
+	{
+		// locking
+		//
+		ACE_MT (ACE_GUARD_RETURN (ACE_Recursive_Thread_Mutex, ace_mon,
+                                *ACE_Static_Object_Lock::instance (), 0));
+
+		if (ACE_High_Res_Timer::gtf_adjust_ ==
+			 ACE_High_Res_Timer::GTF_ADJUST_NOT_INITIALIZED  // first time initialization
+			 ||
+			 ACE_High_Res_Timer::hrt_32hb_ > hrt32 // re-calibration on overflow
+			)
+		{
+			const ACE_Time_Value tv = ACE_OS::gettimeofday ();
+
+			// If coming from the gettimeofday_hr () (<from_gft> is true), 
+			// we are using <hrt_tv> in order not to enter into recursive 
+			// gettimeofday_hr () calls. 
+			// When coming from the constructor, calling gettimeofday_hr () locally.
+			//
+			const ACE_Time_Value tv_hr =  from_gft ? 
+				hrt_tv : ACE_High_Res_Timer::gettimeofday_hr ();
+
+			const ACE_Time_Value delta = (tv > tv_hr) ? (tv - tv_hr) : (tv_hr - tv);
+
+			if (delta.sec () == 0 && delta.usec () < 20000)
+			{
+				// less, than 20 msec timer resolution difference does not require 
+				// adjustment
+				ACE_High_Res_Timer::gtf_adjust_ = 
+					ACE_High_Res_Timer::GTF_ADJUST_NOT_REQUIRED;
+			}
+			else
+			{
+				if (tv > tv_hr)
+				{
+					ACE_hrtime_t hrt = ACE_OS::gethrtime ();
+					ACE_UINT32 hrt_32hb = 
+						static_cast<ACE_UINT32> ((hrt >> 32) & 0x00000000ffffffff);
+
+					ACE_High_Res_Timer::hrt_32hb_ = hrt_32hb;
+					
+					ACE_High_Res_Timer::gtf_adjust_ = 
+						ACE_High_Res_Timer::GTF_ADJUST_REQUIRED;
+
+					ACE_High_Res_Timer::gtf_adjust_tv_ = delta;
+				}
+				else
+				{
+					// error case, could it be?
+					ACE_High_Res_Timer::gtf_adjust_ = 
+						ACE_High_Res_Timer::GTF_ADJUST_NOT_REQUIRED;
+					return -1;
+				}
+			}
+		}
+	}
+	return 0;
+}
