+// This may look like C, but it's really -*- C++ -*-
+
+//=============================================================================
+/**
+ *  @file TSS_Object.h
+ *
+ *  $Id$
+ *
+ *  Define a TAO version of ACE_TSS.  This one tracks all allocations
+ *  stuffed into TSS in a container, and makes it possible to clean them
+ *  up.
+ *
+ *  @author  Chris Cleeland <cleeland_c@ociweb.com>
+ */
+//=============================================================================
+
+
+#ifndef TAO_TSS_OBJECT_H
+#define TAO_TSS_OBJECT_H
+#include "ace/pre.h"
+
+#include "ace/Synch_T.h"
+#include "ace/Containers_T.h"
+
+/**
+ * @class TAO_TSS_Allocation_Record
+ *
+ * @brief Holds a record of a TSS allocation so that it can
+ * get cleaned up later.
+ *
+ * @see TAO_TSS_Object
+ */
+typedef void (*TAO_TSS_Deletion_Func) (void* p);
+struct TAO_TSS_Allocation_Record
+{
+  /// Pointer to the thing that got allocated.  This will get
+  /// cast back to the appropriate type in the deletion function.
+  void *allocation_;
+
+  /// Function called to delete the object pointer to by allocation_.
+  TAO_TSS_Deletion_Func dfunc_;
+
+  /// Convenience constructor to create a record
+  TAO_TSS_Allocation_Record (void *allocation, TAO_TSS_Deletion_Func dfunc);
+
+  /// Comparison operator; we only care that the allocation_ matches
+  int operator== (const TAO_TSS_Allocation_Record &r) const;
+};
+
+
+/**
+ * @class TAO_TSS_Allocation_List
+ *
+ * @brief Container for TAO_TSS_Allocation_Record instances.
+ *
+ */
+class TAO_TSS_Allocation_List
+{
+public:
+  /// Constructor
+  TAO_TSS_Allocation_List (void);
+
+  /// Destructor
+  ~TAO_TSS_Allocation_List (void);
+
+  /// Traits
+  typedef ACE_Unbounded_Set<TAO_TSS_Allocation_Record> TABLE;
+  typedef TABLE::ITERATOR ITERATOR;
+
+  /// Register an allocation based on the pointer and the deletion func.
+  /**
+   * Multiple registrations having the same allocation
+   * pointer <em>do not</em> result in multiple records.
+   *
+   * @return 0 on success, nonzero on failure.
+   */
+  int register_alloc (void *allocation, TAO_TSS_Deletion_Func dfunc);
+
+  /// Unregister an allocation from the list, possibly calling the
+  /// deletion func.
+  /**
+   *  
+   * Deregister the allocation from the list, calling the deletion
+   * func if call_dfunc != 0.
+   */
+  int unregister_alloc (void *allocation, int call_dfunc = 0);
+
+  /// Clean up (i.e., call cleanup func) on all the allocations
+  /// in the list, returning the number cleaned up.
+  int cleanup (void);
+
+  /// Delete all the allocations in the list.  Call this ONLY when
+  /// the ORB itself is going away, i.e., in fini().
+  int delete_and_clean (void);
+
+protected:
+
+private:
+  /// Copy prevention
+  ACE_UNIMPLEMENTED_FUNC (TAO_TSS_Allocation_List (const TAO_TSS_Allocation_List &))
+  ACE_UNIMPLEMENTED_FUNC (void operator= (const TAO_TSS_Allocation_List &))
+
+  TABLE table_;
+};
+
+
+#if 0
+/**
+ * @class TAO_TSS
+ *
+ * @brief Extensions of ACE_TSS which tracks objects held in
+ * thread-specific storage so that they can be cleaned up efficiently
+ * across all threads later.
+ *
+ * @see ACE_TSS
+ */
+template <class TYPE>
+class TAO_TSS : public class
+{
+public:
+  /// Initialize with the <code>ts_obj</code> value, possibly allocating
+  /// a new instance of TYPE.
+  /**
+   * If caller has passed us a non-NULL ts_obj *, then we'll just use
+   * this to initialize the thread-specific value (but only for the
+   * calling thread).  Thus, subsequent calls to <operator->> in this
+   * thread will return this value.  This is useful since it enables
+   * us to assign objects to thread-specific data that have
+   * arbitrarily complex constructors.
+   *
+   * If ts_obj is NULL, then this gets added to the list of allocated
+   * resources to get cleaned up, otherwise not.
+   */
+  TAO_TSS (TYPE *ts_obj = 0);
+
+  /// Deregister with thread-key administration.
+  virtual ~TAO_TSS (void);
+
+  /// Manufactures a new instance of TYPE
+  /**
+   * Manufactures a new instance of TYPE and also stores it
+   * in the list.
+   */
+  virtual TYPE *make_TSS_TYPE (void) const;
+
+  /// Type-safe deletion "function"
+  static delete_TSS_TYPE (void*);
+
+private:
+  // = Disallow copying...
+  ACE_UNIMPLEMENTED_FUNC (void operator= (const ACE_TSS<TYPE> &))
+  ACE_UNIMPLEMENTED_FUNC (ACE_TSS (const ACE_TSS<TYPE> &))
+}
+#endif
+
+
+#if defined (__ACE_INLINE__)
+# include "TSS_Object.inl"
+#endif /* __ACE_INLINE__ */
+
+#include "ace/post.h"
+#endif /* TAO_TSS_OBJECT_H */
