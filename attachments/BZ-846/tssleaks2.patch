@@ -0,0 +1,98 @@
+// -*- C++ -*-
+// $Id$
+
+#include "TSS_Object.h"
+
+ACE_RCSID (tao, TSS_Object, "$Id$")
+
+TAO_TSS_Allocation_List::TAO_TSS_Allocation_List (void)
+{
+}
+
+TAO_TSS_Allocation_List::~TAO_TSS_Allocation_List (void)
+{
+  this->cleanup ();
+}
+
+TAO_TSS_Allocation_Record::TAO_TSS_Allocation_Record (void* allocation = 0, TAO_TSS_Deletion_Func dfunc = 0)
+  : allocation_ (allocation)
+  , dfunc_ (dfunc)
+{
+}
+
+int
+TAO_TSS_Allocation_Record::operator== (const TAO_TSS_Allocation_Record &r) const
+{
+  return (this->allocation_ == r.allocation_);
+}
+
+int
+TAO_TSS_Allocation_List::register_alloc (void *allocation, TAO_TSS_Deletion_Func dfunc)
+{
+  TAO_TSS_Allocation_Record r (allocation, dfunc);
+  return (this->table_.insert (r) == -1) ? -1 : 0;
+}
+
+int
+TAO_TSS_Allocation_List::unregister_alloc (void *allocation, int call_dfunc = 0)
+{       
+  int retval = -1;
+  // Need to use the iterator to find the thing b/c we need to
+  // access the real item in case we have to call the dfunc
+  ITERATOR i (this->table_);
+  TAO_TSS_Allocation_Record recinlist;
+  
+  for (i.first (); ! i.done (); i++)
+    {
+      recinlist = *i;
+      if (recinlist.allocation_ == allocation)
+        {
+          retval = 0;
+          if (call_dfunc)
+            (*recinlist.dfunc_) (recinlist.allocation_);
+          break;
+        }
+    }
+  return (retval == 0) ? (this->table_.remove (recinlist)) : retval;
+}
+
+int
+TAO_TSS_Allocation_List::cleanup (void)
+{
+  int cleanups = 0;
+  ITERATOR i (this->table_);
+  for (i.first (); ! i.done (); i++)
+    {
+      TAO_TSS_Allocation_Record recinlist = *i;
+      if (recinlist.dfunc_)
+        (*recinlist.dfunc_) (recinlist.allocation_);
+      ++cleanups;
+    }
+  return cleanups;
+}
+
+int
+TAO_TSS_Allocation_List::delete_and_clean (void)
+{
+  int deletes = 0;
+  ITERATOR i (this->table_);
+  for (i.first (); ! i.done (); i++)
+    {
+      TAO_TSS_Allocation_Record recinlist = *i;
+      delete recinlist.allocation_;
+      ++deletes;
+    }
+  this->table_.reset ();
+  return deletes;
+}
+
