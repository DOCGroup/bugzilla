+    explicit Blocking_Guard (TAO_Transport *t)
+      : transport_ (t)
+      , restore_nonblock_ (!t->connection_handler ()->get_blocking_io ())
+    {
+      if (this->restore_nonblock_)
+        {
+          t->connection_handler ()->set_blocking_io (true);
+        }
+    }
+
+    ~Blocking_Guard ()
+    {
+      if (this->restore_nonblock_)
+        {
+          this->transport_->connection_handler ()->set_blocking_io (false);
+        }
+    }
+
+    TAO_Transport *transport_;
+    bool restore_nonblock_;
+  };
+}
