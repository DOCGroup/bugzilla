+bool TAO_IIOP_Connection_Handler::get_blocking_io ()
+{
+  return this->blocking_io_;
+}
+
+bool TAO_IIOP_Connection_Handler::set_blocking_io (bool block)
+{
+  if (block == this->blocking_io_)
+    {
+      return true;
+    }
+
+  if (block)
+    {
+      if (this->peer ().disable (ACE_NONBLOCK) == -1)
+        {
+          return false;
+        }
+    }
+  else
+    {
+      if (this->peer ().enable (ACE_NONBLOCK) == -1)
+        {
+          return false;
+        }
+    }
+  this->blocking_io_ = block;
+  return true;
+}
