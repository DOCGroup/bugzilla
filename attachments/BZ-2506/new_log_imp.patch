+ int
+ ACE_Log_Record::encode (char* obuf, const size_t obuf_length)
+ {
+   ACE_TRACE ("ACE_Log_Record::encode");
+ 
+   if ( ( (obuf - (char*)0 ) & (sizeof(uint32_t)-1) ) != 0  )
+         return -1; //  buffer is not aligned on 32 bit border
+ 
+   register uint32_t* obuf_ = reinterpret_cast<uint32_t*>(obuf);
+ 
+   if ( ( obuf_length < static_cast<unsigned long>(this->length()) ) || (obuf_ == 0) || (obuf_length == 0) )
+         return this->length(); // no valid buffer or length, return size of expected buffer
+ 
+ 
+   obuf_[0] = htonl ( this->length() );
+   obuf_[1] = htonl ( this->type_  );
+   obuf_[2] = htonl ( this->secs_  );
+   obuf_[3] = htonl ( this->usecs_ );
+   obuf_[4] = htonl ( this->pid_   );
+   obuf_[5] = htonl ( this->byte_order_ );
+ 
+   ACE_OS::memcpy( obuf_+6, this->msg_data_, this->length_*sizeof(ACE_TCHAR) );
+   return 0;
+ }
+ 
+ int
+ ACE_Log_Record::decode (const char* ibuf, const size_t ibuf_length)
+ {
+   ACE_TRACE ("ACE_Log_Record::decode");
+ 
+   if ( (ibuf-(char*)0) & (sizeof(uint32_t)-1) != 0  ) //  buffer is not aligned on 32 bit border
+         return -1;
+ 
+   register const uint32_t* ibuf_ = reinterpret_cast<const uint32_t*>(ibuf);
+ 
+   if ( ibuf_length > (this->msg_size_ * sizeof(ACE_TCHAR)) ){
+         if(this->msg_size_ && this->msg_data_) delete[] this->msg_data_;
+         ACE_NEW_NORETURN ( this->msg_data_, ACE_TCHAR[ ibuf_length ] );
+         if( this->msg_data_ )
+             this->msg_size_ = ibuf_length;
+         else
+           {
+             this->msg_size_ = 0;
+             return -1; // failed to reallocate internal data buffer
+           }
+   }
+ 
+ 
+ 
+   this->type_ = ntohl( ibuf_[1] );
+   this->pid_ = ntohl( ibuf_[4] );
+   this->byte_order_ = ntohl( ibuf_[5] );
+ 
+   ACE_Time_Value tv (ntohl ( ibuf_[2] ),
+                      ntohl ( ibuf_[3] ));
+ 
+   this->secs_ = tv.sec ();
+   this->usecs_ = tv.usec ();
+ 
+   register uint32_t tmp_len = ntohl( ibuf_[0] ) - sizeof(uint32_t)*6; // length of payload in bytes
+ 
+   // it's not safe to use mixed implementations of ACE_TCHAR
+   // (i.e. one host has ACE_TCHAR=char and another ACE_TCHAR=wchar_t)
+   this->length_ = static_cast<ACE_INT32>( tmp_len / sizeof(ACE_TCHAR) ); // length of payload in ACE_TCHAR
+   ACE_OS::memcpy( this->msg_data_, ibuf_+6, tmp_len);
+   return 0;
+ }
