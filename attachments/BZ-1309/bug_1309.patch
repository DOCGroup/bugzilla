+      // the reactor, so that it isn't included in the set that is
+      // passed to the reactor on ORB destruction.
+      this->transport ()->wait_strategy ()->is_registered (0);
+    }
+
+  // Close the handle..
+  // Remove the entry as it is invalid
+  this->transport ()->purge_entry ();
