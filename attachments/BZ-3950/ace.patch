+int
+operator<< (ACE_OutputCDR &cdr,
+            const ACE_Name_Reply &name_reply)
+{
+  cdr << ACE_CDR::ULong(name_reply.length());
+  cdr << ACE_CDR::Long(name_reply.msg_type());
+  cdr << ACE_CDR::ULong(name_reply.errnum());
+
+  return cdr.good_bit ();
+}
+
+int
+operator>> (ACE_InputCDR &cdr,
+            ACE_Name_Reply &name_reply)
+{
+  ACE_CDR::ULong length;
+  ACE_CDR::Long type;
+  ACE_CDR::ULong errnum;
+
+  if( (cdr >> length) &&
+      (cdr >> type) &&
+      (cdr >> errnum))
+  {
+     name_reply.length(length);
+     name_reply.msg_type(type);
+     name_reply.errnum(errnum);
+  }
+  return cdr.good_bit ();
+}
