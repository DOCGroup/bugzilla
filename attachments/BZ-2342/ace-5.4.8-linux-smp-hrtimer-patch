 int
+ACE_OS::thr_get_affinity (ACE_hthread_t thr_id, ACE_UINT32& cpu_mask)
+{
+#if defined (linux)
+
+#if defined (ACE_HAS_LINUX_NPTL_CPU_AFFINITY)
+	// To compile with NPTL add to CFLAGS -I/usr/include/nptl.
+	// To link to NPTL libraries one normally needs -L/usr/lib/nptl, but on my Debian unstable distro
+	// it was not working till I passed as LIBS =  -L/lib/tls -ldl-2.3.5 -lpthread-2.3.5 -lrt-2.3.5 -lc-2.3.5,
+	// where 2.3.5 is the version of NPTL libs located in /lib/tls.
+	
+	// Handle of the thread, which is NPTL thread-id, normally a big number
+	if (::pthread_getaffinity_np (thr_id, 
+								 sizeof (cpu_mask), 
+								 reinterpret_cast <cpu_set_t *>( &cpu_mask)) != 0)
+	{
+		return -1;
+	}
+	return 0;
+
+#elif defined (ACE_HAS_LINUX_PROCESS_CPU_AFFINITY)
+	
+	// The process-id is expected as <thr_id>, which can be a thread-id of linux-thread,
+	// thus making binding to cpu of that particular thread only.
+	// If you are using this flag for NPTL-threads, however, please pass as a thr_id
+	// process id obtained by ACE_OS::getpid ()
+	if (::sched_getaffinity(thr_id, 
+						   sizeof (cpu_mask),
+						   reinterpret_cast <cpu_set_t *>(&cpu_mask)) == -1)
+	{
+		return -1;
+	}
+	return 0;
+
+#endif /* linux without support for affinity */
+
+#endif /* linux */
+	ACE_UNUSED_ARG (thr_id);
+	ACE_UNUSED_ARG (cpu_mask);
+	ACE_NOTSUP_RETURN (-1);
+}
+
+int
+ACE_OS::thr_set_affinity (ACE_hthread_t thr_id, ACE_UINT32 cpu_mask)
+{
+#if defined (linux)
+
+#if defined (ACE_HAS_LINUX_NPTL_CPU_AFFINITY)
+	if (pthread_setaffinity_np (thr_id, 
+		                                           sizeof (cpu_mask), 
+							     reinterpret_cast <cpu_set_t *> (&cpu_mask)) != 0)
+	{
+		return -1;
+	}
+	return 0;
+#elif defined (ACE_HAS_LINUX_PROCESS_CPU_AFFINITY)
+	// The process-id is expected as <thr_id>, which can be a thread-id of linux-thread,
+	// thus making binding to cpu of that particular thread only.
+	// If you are using this flag for NPTL-threads, however, please pass as a thr_id
+	// process id obtained by ACE_OS::getpid (), but whole process will bind your CPUs
+	//
+	if (sched_setaffinity (thr_id, sizeof (cpu_mask), reinterpret_cast <const cpu_set_t *>(&cpu_mask)) == -1)
+	{
+		return -1;
+	}
+	return 0;
+
+#endif /* linux, without CPU affinity support*/
+
+#endif /* linux */
+
+  ACE_UNUSED_ARG (thr_id);
+  ACE_UNUSED_ARG (cpu_mask);
+  ACE_NOTSUP_RETURN (-1);
+}
