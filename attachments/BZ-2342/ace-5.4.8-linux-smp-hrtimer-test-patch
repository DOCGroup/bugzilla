     }
 
-  ACE_END_TEST;
-  return errors == 0  ?  0  :  1;
+  if (errors)
+  {
+      ACE_END_TEST;
+      return 1;
+  }
+
+#if defined (linux) && \
+((defined (ACE_HAS_SCHED_SETAFFINITY) && defined (ACE_HAS_SCHED_GETAFFINITY)) || \
+ (defined (ACE_HAS_PTHREAD_SETAFFINITY_NP) && defined (ACE_HAS_PTHREAD_GETAFFINITY_NP)))
+
+  ACE_Thread_Manager *thr_mgr = ACE_Thread_Manager::instance ();
+
+  int grp_id = thr_mgr->spawn_n (n_threads, 
+					 (ACE_THR_FUNC) timer_func,
+					 static_cast<void*>(&iterations));
+
+  ACE_ASSERT (grp_id != -1);
+
+  thr_mgr->wait ();
+
+   ACE_END_TEST;
