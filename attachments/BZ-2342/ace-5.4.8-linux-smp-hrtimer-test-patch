+static
+u_int
+smp_safety = 1; // for linux with cpu-affinity
+
+#if defined (linux) && \
+((defined (ACE_HAS_SCHED_SETAFFINITY) && defined (ACE_HAS_SCHED_GETAFFINITY)) || \
+ (defined (ACE_HAS_PTHREAD_SETAFFINITY_NP) && defined (ACE_HAS_PTHREAD_GETAFFINITY_NP)))
+
+static const u_long smp_test_interval = 200000;
+static int smp_errors = 0;
+
+static
+ACE_Time_Value
+smp_time_interval (const ACE_Time_Value &interval,
+               ACE_hrtime_t& nanoseconds,
+		ACE_hrtime_t& microseconds,
+	        int smp_safe)
+{
+  ACE_High_Res_Timer timer;
+
+  if (smp_safe)
+  {
+	  cpu_set_t mask;
+	  CPU_ZERO (&mask);
+
+	  // binding to "CPU 0", works for UP system as well
+	  CPU_SET (0, &mask);
+
+	  if (timer.bind_thread_to_cpu (mask) == -1)
+	  {
+		  ACE_ERROR_RETURN ((LM_ERROR,
+				ACE_TEXT ("bind_thread_to_cpu () failed with errno %d\n"), 
+				errno),
+				1);
+	  }
+  }
+
+  timer.start ();
+
+  // This is to create some probability of a thread migration to
+  // another CPU, when the thread is not bound to a particular CPU
+  // (smp_safe not defined).
+  ACE_OS::thr_yield ();
+
+  ACE_OS::sleep (interval);
+
+  timer.stop ();
+
+  ACE_Time_Value measured;
+  timer.elapsed_time (measured);
+  timer.elapsed_time (nanoseconds);
+  timer.elapsed_microseconds (microseconds);
+  return measured;
+}
+
+static void *
+timer_func (void* data)
+{
+	u_int iterations = *(static_cast<int*> (data));
+
+	for (u_int j = 0; j < iterations; ++j)
+	{
+		const ACE_Time_Value interval (0, smp_test_interval); // 200 msec
+		ACE_hrtime_t nanoseconds;
+		ACE_hrtime_t microseconds;
+		const ACE_Time_Value measured = 
+			smp_time_interval (interval,
+							  nanoseconds,
+							  microseconds,
+							  smp_safety // if 1 smp-safe, if 0 - not-smp-safe 
+				                         );
+
+		ACE_DEBUG ((LM_DEBUG,
+						ACE_TEXT ("interval: %u usec, measured: %u usec%s\n"),
+						interval.sec () * 1000000 + interval.usec (),
+						measured.sec () * 1000000 + measured.usec ()));
+		
+		smp_errors += check (interval.sec () * 1000000 + interval.usec (),
+								  measured.sec () * 1000000 + measured.usec ());
+
+		// Check the ACE_Timer_Value-calculated microseconds against
+		// the ACE_High_Res_Timer-calculated nanoseconds.
+		ACE_DEBUG ((LM_DEBUG,
+						ACE_TEXT ("ACE_Time_Value usec: %u, ACE_HR nsec: %u\n"),
+						measured.sec () * 1000000 + measured.usec (),
+						ACE_HRTIME_CONVERSION (nanoseconds)));
+		
+		smp_errors += check_micro_nano (measured.sec () * 1000000 +
+											 measured.usec (),
+											 nanoseconds);
+		ACE_DEBUG ((LM_DEBUG,
+						ACE_TEXT ("ACE_High_Res_Timer usec: %u, nsec: %u\n"),
+						ACE_HRTIME_CONVERSION (microseconds),
+						ACE_HRTIME_CONVERSION (nanoseconds)));
+		// Now check the ACE_High_Res_Timer-calculated values against
+		// each other.
+		smp_errors += check_micro_nano (microseconds, nanoseconds);
+	}
+	
+	return 0;
+}
+
+#endif /* defined linux with CPU affinity support */
 
 static
 u_int
 intervals [] = {0, 1, 10, 100, 1000, 10000, 100000, 1000000, 4000000}; /*usec*/
 
+static
+u_int 
+n_threads = 13; // 13 - is a really good number
+
+static
+const u_int 
+TIMER_RESOLUTION = 10000;
+
