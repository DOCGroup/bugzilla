+int
+ACE::get_netmask_addr (ACE_UINT32 &netmask_addr,
+                       const ACE_TCHAR *host_name,
+                       const ACE_TCHAR *if_name,
+                       ACE_HANDLE handle)
+{
+    ACE_TRACE ("ACE::get_netmask_addr");
+#if !defined(ACE_WIN32) && !defined(__INTERIX)
+    
+    ACE_TCHAR interface_name[IF_NAMESIZE] ;
+    struct sockaddr_in ip_addr;
+
+    // Get host ip address if necessary.
+    if (host_name)
+    {
+        hostent *hp = ACE_OS::gethostbyname (ACE_TEXT_ALWAYS_CHAR (host_name));  
+        if (hp == 0)
+        {
+            ACE_ERROR_RETURN ((LM_ERROR,
+                               ACE_LIB_TEXT ("ACE::get_netmask_addr () failed\n")
+                               ACE_LIB_TEXT ("ACE_OS::gethostbyname failed for host_name \"%s\"\n"), 
+                               host_name),
+                              -1);
+        }
+        else
+#if !defined(_UNICOS)
+            ACE_OS::memcpy ((char *) &ip_addr.sin_addr.s_addr,
+                            (char *) hp->h_addr,
+                            hp->h_length);
+#else /* _UNICOS */
+        {
+            ACE_UINT64 haddr;  // a place to put the address
+            char * haddrp = (char *) &haddr;  // convert to char pointer
+            ACE_OS::memcpy(haddrp, (char *) hp->h_addr,hp->h_length);
+            ip_addr.sin_addr.s_addr = haddr;
+      }
+#endif /* ! _UNICOS */
+
+        // resolve the sockaddr_in into interface / device name (like "eth0")
+
+        ACE_INET_Addr dev_addr (&ip_addr, sizeof ip_addr);
+        if_name_node_t dev_name;
+
+        if (get_interface_name (dev_addr, 
+                                dev_name) == -1)
+        {
+            char dev_addr_buffer[16];
+            dev_addr.addr_to_string (dev_addr_buffer, sizeof dev_addr_buffer);
+            ACE_ERROR_RETURN ((LM_ERROR,
+                               ACE_LIB_TEXT ("ACE::get_netmask_addr () failed\n")
+                               ACE_LIB_TEXT ("Couldnt find interface for ip-address \"%s\"\n"), dev_addr_buffer),
+                              -1);
+         }
+
+        ACE_OS::strncpy (interface_name, 
+                         (const char*) dev_name.name_, 
+                         sizeof interface_name);
+    }
+    else if (if_name && ACE_OS::strlen (if_name))
+    {
+        ACE_OS::strncpy (interface_name, if_name, sizeof interface_name);
+    }
+    else 
+    {
+        ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("ACE::get_netmask_addr () failed\n")
+                           ACE_LIB_TEXT ("Needs for lookup either hostname/ip-address or interface name\n")),
+                          -1);
+    }
+
+    // get the netmask using name of the interface/device
+    //
+
+    ACE_HANDLE s = handle;
+    if (s == ACE_INVALID_HANDLE)
+        s = ACE_OS::socket (AF_INET, SOCK_DGRAM, 0);
+    
+    if (s == ACE_INVALID_HANDLE)
+        ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("%p\n"),
+                           ACE_LIB_TEXT ("ACE_OS::socket")),
+                          -1);
+
+    struct ifreq if_req;
+    ACE_OS::memset (&if_req, 0, sizeof (struct ifreq)) ;
+
+    ACE_OS::strncpy (if_req.ifr_name, interface_name, sizeof (if_req.ifr_name)) ;
+
+    int result = ACE_OS::ioctl (s, 
+                                SIOCGIFNETMASK, 
+                                (char *)&if_req) ;
+
+    if (result == -1)
+    {
+        ACE_ERROR ((LM_ERROR,
+                    ACE_LIB_TEXT ("%p\n"),
+                    ACE_LIB_TEXT ("ACE::get_netmask_addr:")
+                    ACE_LIB_TEXT ("ioctl (get netmask addr)")));
+    }
+    else
+    {
+        ACE_OS::memcpy (ACE_reinterpret_cast(sockaddr_in *, &ip_addr),
+                        ACE_reinterpret_cast(sockaddr_in *, &if_req.ifr_addr),
+                        sizeof if_req.ifr_addr);
+
+        ACE_OS::memcpy ((void *) &netmask_addr,
+                        (void *) &ip_addr.sin_addr,
+                        sizeof netmask_addr);
+    }
+ 
+    ACE_OS::close (s) ;
+
+    return result;
+#else
+  ACE_UNUSED_ARG (netmask_addr);
+  ACE_UNUSED_ARG (host_name);
+  ACE_UNUSED_ARG (if_name);
+  ACE_UNUSED_ARG (handle);
+  ACE_NOTSUP_RETURN (-1);
+#endif /* !ACE_WIN32 && !__INTERIX */
+}
