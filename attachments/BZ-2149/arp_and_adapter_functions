+int
+ACE::get_interface_index (const ACE_INET_Addr& addr,
+                          int &if_index)
+{
+    ACE_TRACE ("ACE::get_interface_index");
+    
+    if_index = -1;
+
+   if_name_node_t dev_name;
+    
+    if (ACE::get_interface_name (addr, 
+                                 dev_name) == -1)
+        ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("ACE::get_interface_index - failed on\n")
+                           ACE_LIB_TEXT ("ACE::get_interface_name () - error\n")),
+                          -1);
+        
+    struct ifreq if_req;
+    ACE_OS::memset (&if_req, 0, sizeof (struct ifreq));
+
+    ACE_OS::strncpy (if_req.ifr_name, 
+                     (const char*) dev_name.name_, 
+                     sizeof (if_req.ifr_name));
+
+    ACE_HANDLE s = ACE_OS::socket (AF_INET, SOCK_DGRAM, 0);
+    
+    if (s == ACE_INVALID_HANDLE)
+        ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("%p\n"),
+                           ACE_LIB_TEXT ("ACE::get_interface_index - failed on\n")
+                           ACE_LIB_TEXT ("ACE_OS::socket")),
+                          -1);
+    
+    int result = ACE_OS::ioctl (s, 
+                                SIOCGIFINDEX, 
+                                (char*)&if_req);
+    if (result == -1)
+    {
+        ACE_ERROR ((LM_ERROR,
+                    ACE_LIB_TEXT ("%p\n"),
+                    ACE_LIB_TEXT ("ACE::get_interface_mac:")
+                    ACE_LIB_TEXT ("ioctl (get hw addr)")));
+    }
+    else
+    {
+        if_index = if_req.ifr_ifindex;
+    }
+    return result;
+}
