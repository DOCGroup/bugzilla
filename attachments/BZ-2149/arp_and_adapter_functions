+int
+ACE::get_interface_mac (const ACE_INET_Addr& addr,
+                        ACE_OS::macaddr_node_t &mac_addr,
+                        ACE_HANDLE handle)
+{
+    ACE_TRACE ("ACE::get_interface_mac");
+
+    ACE_OS::memset (&mac_addr, 
+                    0,
+                    sizeof mac_addr);
+
+    if_name_node_t dev_name;
+
+    if (ACE::get_interface_name (addr, dev_name) == -1)
+        ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("ACE::get_interface_mac () failed on\n")
+                           ACE_LIB_TEXT ("ACE::get_interface_name - error\n")),
+                          -1);
+
+    int result = ACE::get_interface_mac (dev_name, 
+                                         mac_addr,
+                                         handle);
+    
+    return result;
+}
+
+int
+ACE::get_interface_mac (if_name_node_t& ifname,
+                        ACE_OS::macaddr_node_t &mac_addr,
+                        ACE_HANDLE handle)
+{
+    ACE_TRACE ("ACE::get_interface_mac");
+#if !defined(ACE_WIN32) && !defined(__INTERIX)
+    ACE_HANDLE s = handle;
+
+    if (s == ACE_INVALID_HANDLE)
+        s = ACE_OS::socket (AF_INET, SOCK_DGRAM, 0);
+    
+    if (s == ACE_INVALID_HANDLE)
+        ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("%p\n"),
+                           ACE_LIB_TEXT ("ACE_OS::socket")),
+                          -1);
+
+    // get the hw-address using name of the interface/device
+    //
+    struct ifreq if_req;
+    ACE_OS::memset (&if_req, 0, sizeof (struct ifreq)) ;
+    
+    ACE_OS::strncpy (if_req.ifr_name, 
+                     (const char*) ifname.name_, 
+                     sizeof (if_req.ifr_name)) ;
+    
+    int result = ACE_OS::ioctl (s, 
+                                SIOCGIFHWADDR, 
+                                (char *)&if_req);
+    
+    if (result == -1)
+    {
+        ACE_ERROR ((LM_ERROR,
+                    ACE_LIB_TEXT ("%p\n"),
+                    ACE_LIB_TEXT ("ACE::get_interface_mac:")
+                    ACE_LIB_TEXT ("ioctl (get hw addr)")));
+    }
+    else
+    {
+        char mac_human[18] ;
+        ACE_OS::sprintf (mac_human,
+                                 "%02x:%02x:%02x:%02x:%02x:%02x", 
+                                 (u_char) if_req.ifr_hwaddr.sa_data[0],
+                                 (u_char) if_req.ifr_hwaddr.sa_data[1],
+                                 (u_char) if_req.ifr_hwaddr.sa_data[2],
+                                 (u_char) if_req.ifr_hwaddr.sa_data[3],
+                                 (u_char) if_req.ifr_hwaddr.sa_data[4],
+                                 (u_char) if_req.ifr_hwaddr.sa_data[5]) ;
+
+        ACE_DEBUG ((LM_DEBUG, 
+                    "ACE::get_interface_mac: - mac %s found \n", mac_human));
+        
+
+        // copy now  the raw data mac (ok for ether_data on linux)
+        ACE_OS::memcpy (mac_addr.node, 
+                        &if_req.ifr_hwaddr.sa_data, 
+                        sizeof mac_addr.node);
+    }
+
+    ACE_OS::close (s);
+
+    return result;
+
+#else
+  ACE_UNUSED_ARG (netmask_addr);
+  ACE_UNUSED_ARG (host_name);
+  ACE_UNUSED_ARG (if_name);
+  ACE_UNUSED_ARG (handle);
+  ACE_NOTSUP_RETURN (-1);
+#endif /* !ACE_WIN32 && !__INTERIX */
+}
