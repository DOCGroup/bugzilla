+  /// The broadcasting address of ethernet
+  static const ether_addr ethernet_broadcast_address = {{0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF}};
+}
+
+int
+ACE::prepare_arp_request_msg (const ACE_INET_Addr &src_ip,
+                              const ACE_INET_Addr &target_ip,
+                              Arp_Message &arp_req)
+{
+    ACE_TRACE ("ACE::prepare_arp_request_msg");
+
+    struct ether_addr src_ethernet_addr, dst_ethernet_addr;
+
+    ACE_OS::macaddr_node_t src_mac;
+
+    if (get_interface_mac (src_ip,
+                           src_mac) == -1)
+        ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("ACE::get_lan_mac_by_arp () - ")
+                           ACE_LIB_TEXT ("ACE::get_interface_mac () - error\n")),
+                          -1);
+
+    ACE_OS::memcpy (&src_ethernet_addr,
+                    &src_mac.node, 
+                    sizeof (struct ether_addr));
+
+    // For all other cases destination MAC shall be the broadcast address
+    ACE_OS::memcpy (&dst_ethernet_addr, 
+                    &ACE::ethernet_broadcast_address,
+                    sizeof (struct ether_addr));
+
+    ACE_OS::memset (&arp_req, 0, sizeof arp_req) ;
+
+    //
+    // ethernet header
+    //
+
+    // mac-destination is the ethernet broadcast mac, if not gra...
+    ACE_OS::memcpy (arp_req.ethhdr_.ether_dhost, &dst_ethernet_addr, ETH_ALEN);
+    // mac-source is the outbound interface hw address
+    ACE_OS::memcpy (arp_req.ethhdr_.ether_shost, &src_ethernet_addr, ETH_ALEN);
+
+    arp_req.ethhdr_.ether_type = htons(ETHERTYPE_ARP);
+    arp_req.hw_type_	= htons(ARPHRD_ETHER);
+    arp_req.prot_type_	= htons(ETHERTYPE_IP);
+    arp_req.hw_len_	= ETH_ALEN;
+    arp_req.prot_len_	= 4; // ip-addresses
+    arp_req.op_	        = htons(ARPOP_REQUEST);
+
+    // source is the outbound interface hw address
+    ACE_OS::memcpy (arp_req.src_hw_addr_, &src_ethernet_addr, ETH_ALEN);
+
+    
+    ACE_UINT32 ip_s = 0;
+    if (target_ip == src_ip)
+    {
+        // vip for gratituious ARP
+        ip_s = target_ip.get_ip_address ();
+        ip_s = ACE_HTONL (ip_s);
+    }
+    else
+    {
+        // source ip of the outbound interface
+        ip_s = src_ip.get_ip_address ();
+        ip_s = ACE_HTONL (ip_s);
+    }
+    ACE_OS::memcpy (arp_req.src_ip_addr_, &ip_s, sizeof (arp_req.src_ip_addr_));
+
+    // target/destination ip-address, for which MAC we are looking for.
+    ACE_UINT32 ip_d = target_ip.get_ip_address ();
+    ip_d = ACE_HTONL (ip_d);
+    ACE_OS::memcpy (&arp_req.target_ip_addr_, &ip_d, sizeof (arp_req.target_ip_addr_));
+
+    // target/destination MAC shall be zero in ARP-request 
+    //
+
+    return 0;
+}
+
+int
+ACE::send_arp_message (Arp_Message& arp_msg,
+                       const int if_index,
+                       ACE_HANDLE &socket)
+{  
+    ACE_TRACE ("ACE::send_arp_message");
+
+    struct sockaddr_ll ll_addr;
+
+    // Open ARP-socket
+    //
+    if (socket == ACE_INVALID_HANDLE)
+    {
+        socket = ACE_OS::socket (AF_PACKET, 
+                                 SOCK_RAW, 
+                                 htons(ETH_P_ARP));
+
+        if (socket == ACE_INVALID_HANDLE)
+        {
+            ACE_ERROR_RETURN ((LM_ERROR,
+                               ACE_LIB_TEXT ("%p\n"),
+                               ACE_LIB_TEXT ("ACE::send_arp_message (): ")
+                               ACE_LIB_TEXT ("ACE_OS::socket")),
+                              -1);
+        }
+
+        // Bind ARP-socket to the relevant interface
+        //
+        ACE_OS::memset (&ll_addr, 0, sizeof ll_addr);
+        ll_addr.sll_family = AF_PACKET;
+        ll_addr.sll_protocol = htons (ETH_P_ARP);
+        ll_addr.sll_ifindex = if_index;
+        
+        if (ACE_OS::bind (socket,
+                          (sockaddr*)&ll_addr,
+                          sizeof (ll_addr)) == -1)
+        {
+            ACE_OS::close (socket);
+            socket = ACE_INVALID_HANDLE;
+
+            ACE_ERROR_RETURN ((LM_ERROR,
+                               ACE_LIB_TEXT ("%p\n"),
+                               ACE_LIB_TEXT ("ACE::send_arp_message (): ")
+                               ACE_LIB_TEXT ("ACE_OS::bind")),
+                              -1);
+        }
+    }
+
+    // Send ARP-request finally
+    if (ACE_OS::sendto (socket,
+                        (char const *) &arp_msg,
+                        sizeof (arp_msg),
+                        0,
+                        (sockaddr const *) &ll_addr,
+                        sizeof (ll_addr)) == -1)
+    {
+        ACE_OS::close (socket);
+        socket = ACE_INVALID_HANDLE;
+
+        ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("%p\n"),
+                           ACE_LIB_TEXT ("ACE::send_arp_message (): ")
+                           ACE_LIB_TEXT ("ACE_OS::sendto")),
+                          -1);
+    }
+    return 0;
+}
+
+int
+ACE::get_lan_mac_by_arp (ACE_OS::macaddr_node_t &target_mac,
+                         const ACE_INET_Addr &src_ip,
+                         const ACE_INET_Addr &target_ip,
+                         size_t arp_requests_number,             // 2- default
+                         const ACE_Time_Value &timeout)  // ACE::arp_wait_default_timeout
+{
+    ACE_TRACE ("ACE::get_lan_mac_by_arp");
+
+    Arp_Message arp_msg;
+
+    if (ACE::prepare_arp_request_msg (src_ip,
+                                      target_ip,
+                                      arp_msg) == -1)
+    {
+         ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("ACE::get_lan_mac_by_arp () - ")
+                           ACE_LIB_TEXT ("ACE::prepare_arp_request_msg () - failed.\n")),
+                          -1);
+    }
+    
+    // Fetch index of the interface
+    int index = -1;
+    if (ACE::get_interface_index (src_ip, 
+                                  index) == -1 ||  index < 0)
+        ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("ACE::get_lan_mac_by_arp () - ")
+                           ACE_LIB_TEXT ("ACE::get_interface_mac () - error\n")),
+                          -1);
+
+    ACE_HANDLE socket = ACE_INVALID_HANDLE;
+
+    int result = -1;
+
+    do
+    {
+        if (ACE::send_arp_message (arp_msg,
+                                   index,
+                                   socket) == -1)
+        {
+            ACE_ERROR_RETURN ((LM_ERROR,
+                               ACE_LIB_TEXT ("ACE::get_lan_mac_by_arp () - ")
+                               ACE_LIB_TEXT ("ACE::send_arp_message () - failed.\n")),
+                              -1);
+        }
+        
+        result = ACE::receive_arp_reply (target_mac,
+                                         src_ip,
+                                         target_ip,
+                                         socket,
+                                         timeout);
+        if (result < 0)
+        {
+            // returns -2 on timeout
+            ACE_DEBUG ((LM_DEBUG, 
+                        ACE_LIB_TEXT ("ACE::get_lan_mac_by_arp: - ")
+                        ACE_LIB_TEXT ("timeout of ACE::receive_arp_reply () passed")
+                        ACE_LIB_TEXT ("or there is an error with errno %d"), errno));
+        }
+        
+        ACE_OS::sleep (ACE_Time_Value (0, 20000)); // wait for 20 msec and send it once more
+        if (socket != ACE_INVALID_HANDLE)
+        {
+            ACE_OS::close (socket);
+            socket = ACE_INVALID_HANDLE;
+        }
+
+    } while (result && arp_requests_number-- > 0);
+
+    if (! result)
+    {
+        char mac_human[18] ;
+        ACE_OS::sprintf (mac_human,
+                         "%02x:%02x:%02x:%02x:%02x:%02x",
+                         (u_char) target_mac.node[0],
+                         (u_char) target_mac.node[1],
+                         (u_char) target_mac.node[2],
+                         (u_char) target_mac.node[3],
+                         (u_char) target_mac.node[4],
+                         (u_char) target_mac.node[5]);
+        
+        ACE_DEBUG ((LM_DEBUG, 
+                    "ACE::get_lan_mac_by_arp - mac \"%s\" responded.\n", mac_human));
+    }
+
+    return result ;
+}
+
+int
+ACE::receive_arp_reply (ACE_OS::macaddr_node_t &target_mac_req,
+                        const ACE_INET_Addr &src_ip_req,
+                        const ACE_INET_Addr &target_ip_req,
+                        ACE_HANDLE handle,
+                        const ACE_Time_Value &timeout)
+{
+    ACE_TRACE ("ACE::receive_arp_reply");
+
+    ACE_Time_Value after,
+        before = ACE_OS::gettimeofday (),
+        wait_time = timeout;
+
+    const ACE_Time_Value half_millisec (0, 500);
+
+    Arp_Message arp_msg;
+
+    do
+    {
+        int rval_recv = ACE::recv (handle,
+                                   &arp_msg,
+                                   sizeof arp_msg,
+                                   0, // flags
+                                   &wait_time);
+
+        if  (rval_recv < 0)
+        {
+            if (errno == EINTR)
+            {
+                after = ACE_OS::gettimeofday ();
+                ACE_Time_Value time_left = timeout - after + before;
+                
+                if (time_left > half_millisec)
+                {
+                    // if more than 0.5 ms left, lets come to wait on select()
+                    wait_time = time_left;
+                    continue;
+                }
+                else
+                {
+                    errno = ETIME;
+                    return -2 ; // timeout expired
+                }
+            }
+            ACE_ERROR_RETURN ((LM_ERROR,
+                               ACE_LIB_TEXT ("%p\n"),
+                               ACE_LIB_TEXT ("ACE::receive_arp_reply: ")
+                               ACE_LIB_TEXT ("recv (receive arp reply)")),
+                              -1);
+        }
+        else if ( !ACE::process_inbound_arp (target_mac_req,
+                                             src_ip_req,
+                                             target_ip_req,
+                                             arp_msg))
+        {
+            // success !!!
+            return 0;
+        }
+        else
+        {
+            // we got not arp-reply, arp-reply not for us, etc, etc, etc
+            
+            after = ACE_OS::gettimeofday ();
+            
+            if ((after - before) >= timeout)
+            {
+                errno = ETIME;
+                ACE_ERROR_RETURN ((LM_ERROR,
+                                   ACE_LIB_TEXT ( "%p\n"),
+                                   ACE_LIB_TEXT ("ACE::receive_arp_reply: ")
+                                   ACE_LIB_TEXT ("select returned 0, timed out.")),
+                                  -2);
+            }
+            // new timeout, we are coming back to sit on select
+            wait_time = timeout - after + before;
+        }
+    
+    } while (wait_time >= half_millisec);
+
+    return -2; // means timeout
+}
+
+int
+ACE::process_inbound_arp (ACE_OS::macaddr_node_t &target_mac,
+                          const ACE_INET_Addr &src_ip_req,
+                          const ACE_INET_Addr &target_ip_req,
+                          Arp_Message &arp_msg)
+{
+    if (
+        (ACE_NTOHS (arp_msg.ethhdr_.ether_type) == ETHERTYPE_ARP) &&  // 1. this is ARP
+        (ACE_NTOHS (arp_msg.op_) == ARPOP_REPLY) &&      // 2. this is ARP-reply
+        (((sockaddr_in *)src_ip_req.get_addr ())->sin_addr.s_addr == 
+         *((in_addr_t *)arp_msg.target_ip_addr_)) &&                         // 3. SrcIP of ARP-Request == TargetIP of Reply
+        (((sockaddr_in *)target_ip_req.get_addr ())->sin_addr.s_addr ==
+         *((in_addr_t *)arp_msg.src_ip_addr_))                                    // 4. TargetIP of ARP-Request == SrcIP of Reply
+        )
+    {
+        ACE_OS::memcpy (target_mac.node, 
+                        arp_msg.src_hw_addr_, 
+                        sizeof (target_mac.node)) ;
+        return 0;
+    }
+    
+    ACE_DEBUG ((LM_DEBUG, 
+                    "ACE::process_inbound_arp: - not expected ARP-reply\n"));
+    return -1;
+}
