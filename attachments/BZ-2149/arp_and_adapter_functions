+int
+ACE::get_interface_name (const ACE_INET_Addr& addr,
+                         if_name_node_t& ifname)
+{
+    ACE_TRACE ("ACE::get_interface_name");
+
+    ACE_OS::memset (&ifname, 
+                    0, 
+                    sizeof ifname);
+
+    size_t count = 0;
+    ACE_INET_Addr *addrs = 0;
+    if_name_node_t* interfaces = 0;
+
+    if ((ACE::get_ip_interfaces (count,
+                                 addrs,
+                                 &interfaces) == -1) || !addrs || !interfaces)
+    {
+        ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("ACE::get_interface_name () failed\n")
+                           ACE_LIB_TEXT ("ACE::get_ip_interfaces - error\n")),
+                          -1);
+    }
+    
+    int result = -1;
+
+    for (size_t i = 0 ; i < count ; i++)
+    {
+        if (addr == addrs[i])
+        {
+            ACE_OS::strncpy ((char *) ifname.name_, 
+                             (const char *) interfaces[i].name_, 
+                             sizeof ifname.name_);
+            result = 0;
+            break;
+        }
+    }
+
+    delete [] interfaces;
+    delete [] addrs;
+
+    return result;
+}
