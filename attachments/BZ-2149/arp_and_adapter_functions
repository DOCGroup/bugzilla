+struct Arp_Message
+{
+    
+    struct ether_header	ethhdr_ ;
+
+    // The hardware type for ethernet ARPHRD_ETHER.
+    ACE_UINT16 hw_type_ ;
+
+    // Protocol type to be ETHERTYPE_IP.
+    ACE_UINT16 prot_type_ ;
+
+    // Hardware address length, which is 6 for ethernet mac
+    u_char  hw_len_ ;
+
+    // Protocol addr lenght, which is 4 for IP addresses
+    u_char  prot_len_ ;		/* protocol address length (must be 4) */
+
+    // ARP operation code
+    u_short op_ ;
+
+    // Source (sender) hw addr
+    u_char  src_hw_addr_ [ETH_ALEN];
+
+    // Source (sender) IPv4 addr
+    u_char  src_ip_addr_ [4];
+
+    // Destination hw addr
+    u_char  target_hw_addr_ [ETH_ALEN];
+
+    // Destination IPv4 addr
+    u_char  target_ip_addr_ [4];
+
+    // Padding yo minimal ethernet payload (60 bytes)
+    u_char  pad_ [18];
+} ;
