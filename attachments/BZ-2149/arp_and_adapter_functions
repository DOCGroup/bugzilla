+int
+ACE::get_interface_ip_address (if_name_node_t &ifname,
+                               ACE_INET_Addr &addr)
+{
+    ACE_TRACE ("ACE::get_interface_ip_address");
+
+    size_t count = 0;
+    ACE_INET_Addr *addresses = 0;
+    if_name_node_t* interfaces = 0;
+
+    if ((ACE::get_ip_interfaces (count,
+                                 addresses,
+                                 &interfaces) == -1) || !addresses || !interfaces)
+    {
+        ACE_ERROR_RETURN ((LM_ERROR,
+                           ACE_LIB_TEXT ("ACE::get_interface_name () - ")
+                           ACE_LIB_TEXT ("ACE::get_ip_interfaces - error\n")),
+                          -1);
+    }
+    
+    int result = -1;
+
+    for (size_t i = 0 ; i < count ; i++)
+    {
+        if (! ACE_OS::strcmp ((const char*) ifname.name_, 
+                              (const char*) interfaces[i].name_) )
+        {
+            addr = addresses[i];
+            result = 0;
+            break;
+        }
+    }
+
+    delete [] addresses;
+    delete [] interfaces;
+
+    return result;
+}
