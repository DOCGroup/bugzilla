+          // missing_data_bytes_ now has the full GIOP message size, so we allocate
+          // a new message block of that size, plus the header.
+          new_qd->msg_block_ = clone_mb_nocopy_size  (mb,
+                                                      new_qd->missing_data_bytes_ +
+                                                      HDR_LEN);
