+struct Multi_Args
+{
+public:
+  Multi_Args(ACE_Barrier *barrier, long i)
+      : barrier_(barrier)
+      , i_(i)
+  {
+  }
+  ACE_Barrier *barrier_;
+  long i_;
+};
+
+static void *
+wait_multi(void *arguments)
+{
+  Multi_Args *arg= (Multi_Args*)arguments;
+  ACE_DEBUG((LM_DEBUG,"Thread (%t) Created to do some work: %d\n", arg->i_));
+
+  //Work
+  
+  //Let the barrier know we are done.
+  ACE_DEBUG((LM_DEBUG,"Thread (%t) is exiting \n"));
+  arg->barrier_->wait();
+  delete arg;
+  return 0;
+}
+
+
 #endif /* ACE_HAS_THREADS */
 
