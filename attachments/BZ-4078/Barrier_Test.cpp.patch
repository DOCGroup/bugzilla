+  // with their own parameters.
+
+  // Create barrier for multiple threads.
+  ACE_Barrier multi_barrier(n_threads);
+
+  // Create threads with their parameters.
+  std::auto_ptr<Multi_Args *> array_of_args(new Multi_Args *[n_threads]);
+  for (int i = 0; i != n_threads; i++)
+    array_of_args.get()[i] = new Multi_Args(&multi_barrier, i);
+
