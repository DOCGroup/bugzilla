+class Event_Scheduler : public ACE_Task<ACE_MT_SYNCH>
+{
+ public:
+  Event_Scheduler(TimerQueueAdapterBase_t* tqa,
+									ICustomEventHandler* eh,
+									ACE_Time_Value* p,
+									ACE_Time_Value* md)
+	 : tqa_(tqa),
+		 eh_(eh),
+		 p_(p),
+		 md_(md),
+		 e_(0) { }
+
+	virtual int svc()
+	{
+		ACE_ASSERT(tqa_);
+		ACE_ASSERT(eh_);
+		ACE_ASSERT(p_);
+		ACE_ASSERT(md_);
+
+		long timer_id = 0;
+		long timer_act = 1;
+		int i = 0;
+		double coefficient =
+			static_cast<double>(md_->msec()) / (RAND_MAX + 1.0F);
+		ACE_Time_Value delay = ACE_Time_Value::zero;
+		unsigned int seed = static_cast<unsigned int>(ACE_OS::time(0L));
+		do
+		{
+			if (*md_ != ACE_Time_Value::zero)
+			{
+				delay.usec(static_cast<suseconds_t>(coefficient * ACE_OS::rand_r(&seed) * 1000));
+				ACE_OS::sleep(delay);
+			} // end IF
+
+			timer_id = tqa_->schedule(eh_,
+															  &timer_act,
+															  ACE_OS::gettimeofday() + p_[i++],
+															  ACE_Time_Value::zero);
+			if (timer_id == -1)
+			{
+				ACE_DEBUG((LM_ERROR,
+					         ACE_TEXT("failed to schedule timer: \"%m\", continuing\n")));
+			} // end IF
+			ACE_TEST_ASSERT(timer_id != -1);
+			e_++;
+
+			if (i == max_iterations)
+				i = 0;
+		} while (msg_queue_->is_empty());
+
+		// clean up
+		msg_queue_->flush();
+
+		//ACE_DEBUG((LM_DEBUG,
+		//	         ACE_TEXT("scheduler thread leaving...\n")));
+
+		return 0;
+	}
+
+	void set_maximum_delay(ACE_Time_Value* md) { md_ = md; }
+	unsigned int num_scheduled() const { return e_; }
+	void reset() { e_ = 0; }
+
+ private:
+  TimerQueueAdapterBase_t* tqa_;
+	ICustomEventHandler* eh_;
+	ACE_Time_Value* p_;
+	ACE_Time_Value* md_;
+	unsigned int e_;
+};
 
