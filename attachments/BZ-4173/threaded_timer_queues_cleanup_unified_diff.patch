+class Event_Scheduler : public ACE_Task<ACE_MT_SYNCH>
+{
+ public:
+	Event_Scheduler(ACE_Timer_Queue* tq,
+				 	        ACE_Event_Handler* eh,
+	                ACE_Time_Value* p,
+									ACE_Time_Value* md)
+	 : tq_(tq),
+	   eh_(eh),
+	   p_(p),
+		 md_(md),
+		 e_(0) {	}
+
+	virtual int svc()
+	{
+		ACE_ASSERT(tq_);
+		ACE_ASSERT(eh_);
+		ACE_ASSERT(p_);
+		ACE_ASSERT(md_);
+
+		long timer_id = 0;
+		int timer_act = 42;
+		int i = 0;
+		double coefficient =
+			static_cast<double>(md_->msec()) / (RAND_MAX + 1.0F);
+		ACE_Time_Value delay = ACE_Time_Value::zero;
+		unsigned int seed = static_cast<unsigned int>(ACE_OS::time(0L));
+		int random_number = 0;
+		do
+		{
+			if (*md_ != ACE_Time_Value::zero)
+			{
+				random_number = ACE_OS::rand_r(&seed);
+				delay.usec(static_cast<suseconds_t>(coefficient * static_cast<double>(random_number) * 1000.0F));
+				ACE_OS::sleep(delay);
+			} // end IF
+
+			timer_id = tq_->schedule(eh_,
+															 &timer_act,
+															 tq_->gettimeofday() + p_[i++],
+															 ACE_Time_Value::zero);
+			ACE_ASSERT(timer_id != -1);
+			e_++;
+
+			if (i == max_iterations)
+				i = 0;
+		} while (msg_queue_->is_empty());
+
+		// clean up
+		msg_queue_->flush();
+
+		//ACE_DEBUG((LM_DEBUG,
+		//	         ACE_TEXT("scheduler thread leaving...\n")));
+
+		return 0;
+	}
+
+	void set_maximum_delay(ACE_Time_Value* md) { md_ = md; }
+	unsigned int num_scheduled() const { return e_; }
+	void reset() { e_ = 0; }
+
+ private:
+  ACE_Timer_Queue* tq_;
+	ACE_Event_Handler* eh_;
+	ACE_Time_Value* p_;
+	ACE_Time_Value* md_;
+	unsigned int e_;
+};
+
+static void
+test_stability(ACE_Timer_Queue* tq)
+{
+	ACE_ASSERT(tq->is_empty() != 0);
+	ACE_ASSERT(ACE_Time_Value::zero == ACE_Time_Value(0));
+
+	// Test brute-force scheduling behaviour
+
+	ACE_Message_Block* stop = 0;
+	ACE_NEW_NORETURN(stop, ACE_Message_Block((ACE_Allocator*)NULL));
+	ACE_ASSERT(stop != 0);
+	stop->msg_type(ACE_Message_Block::MB_STOP);
+
+	Example_Handler handler;
+	ACE_Event_Handler* eh = &handler;
+    int remaining_timers = 0;
+
+	// Set up a bunch of times TIMER_DISTANCE ms apart.
+	ACE_Time_Value *periods = 0;
+	ACE_NEW_NORETURN(periods, ACE_Time_Value[max_iterations]);
+	ACE_ASSERT(periods != 0);
+	for (int i = 0; i < max_iterations; ++i)
+      periods[i] = ACE_Time_Value(0, i * TIMER_DISTANCE * 1000);
+	randomize(periods,
+              max_iterations,
+              static_cast<unsigned int>(ACE_OS::time(0L)));
+
+	ACE_Time_Value maximum_delay = ACE_Time_Value::zero;
+
+	Event_Scheduler scheduler(tq,
+                              &handler,
+                              periods,
+                              &maximum_delay);
+
+	ACE_Message_Block* mb = stop->duplicate();
+	ACE_ASSERT(mb != 0);
+	mb->msg_type(ACE_Message_Block::MB_STOP);
+
+	ACE_Profile_Timer timer;
+	ACE_Profile_Timer::ACE_Elapsed_Time elapsed_time;
+
+	timer.start();
+
+	scheduler.activate();
+	ACE_OS::sleep(bf_running_time);
+	scheduler.putq(mb);
+	scheduler.wait();
+	remaining_timers = tq->cancel(eh, 1);
+
+	timer.stop();
+	timer.elapsed_time(elapsed_time);
+	ACE_DEBUG((LM_DEBUG,
+               ACE_TEXT("brute-force scheduling: %#T --> %d events (real/user/system secs): \t%.3f / %.3f / %.3f\n"),
+               &bf_running_time, scheduler.num_scheduled(), elapsed_time.real_time, elapsed_time.user_time, elapsed_time.system_time));
+	ACE_TEST_ASSERT(tq->is_empty());
+
+	maximum_delay = maximum_interval;
+
+	mb = stop->duplicate();
+	ACE_ASSERT(mb != 0);
+	mb->msg_type(ACE_Message_Block::MB_STOP);
+
+	timer.start();
+
+	scheduler.reset();
+	scheduler.set_maximum_delay(&maximum_delay);
+	scheduler.activate();
+	ACE_OS::sleep(rd_running_time);
+	scheduler.putq(mb);
+	scheduler.wait();
+	remaining_timers = tq->cancel(eh, 1);
+
+	timer.stop();
+	timer.elapsed_time(elapsed_time);
+	ACE_DEBUG((LM_DEBUG,
+               ACE_TEXT("random delay scheduling: %#T --> %d events (real/user/system secs): \t\t%.3f / %.3f / %.3f\n"),
+               &rd_running_time, scheduler.num_scheduled(), elapsed_time.real_time, elapsed_time.user_time, elapsed_time.system_time));
+	ACE_ASSERT(tq->is_empty());
+
+	// clean up
+	delete stop;
+}
