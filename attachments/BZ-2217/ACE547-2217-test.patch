+// Test that ACE_Pagefile_memory_Pool returns the true
+// base address of the memory pool
+//
+// ACE_MMAP_memory_Pool is used to obtain a base address
+// that memory can be mapped to, this address is then
+// freed and used to map an ACE_Pagefile_memory_Pool.
+// The base address retuned by the ACE_Pagefile_Memory_Pool
+// is then compared to the known base address.
+//
+// The result of this test alters the way subsequent tests
+// are performed using the ACE_Pagefile_Memory_Pool
+// (See http://deuce.doc.wustl.edu/bugzilla/show_bug.cgi?id=2217)
+//
+#if defined (ACE_WIN32)
+static int 
+pagefile_base_addr_test (PF_MALLOC* pfmalloc, const void* ba)
+{
+    // Get the base address
+    void* pf_baddr = pfmalloc->base_addr();
+
+    // Now check that the base address returned by
+    // both pools is the same
+    if (pf_baddr != ba)
+    {
+	ACE_ERROR_RETURN ((LM_ERROR,
+	    ACE_TEXT ("ACE_Pagefile_memory_Pool does not return correct base address\n")),
+	    -1);
+    }
+    return 0;
+}
+#endif /* ACE_WIN32 */
