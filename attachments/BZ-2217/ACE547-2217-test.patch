+#if defined (ACE_WIN32)
+static PF_MALLOC*
+my_pfallocator (const void *base_addr = 0)
+{
+  static auto_ptr<PF_MALLOC> static_allocator;
+
+  if (static_allocator.get () == 0)
+    {
+
+#if defined (ACE_HAS_WINCE)
+      // WinCE cannot do fixed base, ever.
+      ACE_Pagefile_Memory_Pool_Options options (ACE_DEFAULT_PAGEFILE_POOL_BASE);
+#else
+      ACE_Pagefile_Memory_Pool_Options options (const_cast<void*>(base_addr));
+#endif /* ACE_HAS_WINCE */
+
+      PF_MALLOC *ptr = new PF_MALLOC (MMAP_FILENAME,
+                                MUTEX_NAME,
+                                &options);
+      ACE_AUTO_PTR_RESET(static_allocator, ptr, PF_MALLOC);
+    }
+  return static_allocator.get ();
+}
+#endif /* ACE_WIN32 */
