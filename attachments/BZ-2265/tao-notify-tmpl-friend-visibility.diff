diff -rubwN ACE-bleeding/ace/config-g++-common.h ACE-current/ace/config-g++-common.h
--- ACE-bleeding/ace/config-g++-common.h	2005-10-11 11:20:25.000000000 -0400
+++ ACE-current/ace/config-g++-common.h	2005-10-13 18:06:11.000000000 -0400
@@ -84,9 +84,12 @@
 // As a workaround, we use the GCC visibility pragmas.
 // And to make them fit in a macro, we use C99's _Pragma()
 // http://gcc.gnu.org/bugzilla/show_bug.cgi?id=17470
-#  if 0 /* ... replace if/when gcc bug 17470 is fixed */
+#  undef GCC_HAS_TEMPLATE_INSTANTIATION_VISIBILITY_ATTRS /* @@ update this if/when gcc bug 17470 is fixed */
+#  ifdef GCC_HAS_TEMPLATE_INSTANTIATION_VISIBILITY_ATTRS
 #   define ACE_EXPORT_SINGLETON_DECLARATION(T) template class ACE_Proper_Export_Flag T
 #   define ACE_EXPORT_SINGLETON_DECLARE(SINGLETON_TYPE, CLASS, LOCK) template class ACE_Proper_Export_Flag SINGLETON_TYPE <CLASS, LOCK>;
+#   define ACE_EXPORT_SINGLETON_FRIENDSHIP(T) friend class ACE_Proper_Export_Flag T
+#   define ACE_EXPORT_SINGLETON_FRIEND(SINGLETON_TYPE, CLASS, LOCK) friend class ACE_Proper_Export_Flag SINGLETON_TYPE <CLASS, LOCK>;
 #  else  /* ! GCC_HAS_TEMPLATE_INSTANTIATION_VISIBILITY_ATTRS */
 #   define ACE_EXPORT_SINGLETON_DECLARATION(T)     \
         _Pragma ("GCC visibility push(default)")  \
@@ -96,6 +99,14 @@
         _Pragma ("GCC visibility push(default)")                    \
         template class SINGLETON_TYPE<CLASS, LOCK>;                 \
         _Pragma ("GCC visibility pop")
+#   define ACE_EXPORT_SINGLETON_FRIENDSHIP(T)    \
+        _Pragma ("GCC visibility push(default)") \
+        friend class T                           \
+        _Pragma ("GCC visibility pop")
+#   define ACE_EXPORT_SINGLETON_FRIEND(SINGLETON_TYPE, CLASS, LOCK) \
+        _Pragma ("GCC visibility push(default)")                    \
+        friend class SINGLETON_TYPE<CLASS, LOCK>;                   \
+        _Pragma ("GCC visibility pop")
 #  endif /* ! GCC_HAS_TEMPLATE_INSTANTIATION_VISIBILITY_ATTRS */
 
 #  define ACE_IMPORT_SINGLETON_DECLARATION(T) extern template class T
