 void
+TAO_ECG_Complex_Address_Server::get_ip_address (
+                         const RtecEventComm::EventHeader& header,
+                         RtecUDPAdmin::UDP_IP_Address_out addr6)
+{
+  CORBA::Long key;
+  if (this->is_source_mapping_)
+    key = header.source;
+  else
+    key = header.type;
+
+  addr6 = new RtecUDPAdmin::UDP_IP_Address;
+
+  MAP::ENTRY * mapping_entry = 0;
+  if (this->mcast_mapping_.find (key, mapping_entry) == -1)
+    {
+      // Key was not found in the mapping.  Use default.
+      addr6->length(this->default_addr_.get_addr_size());
+      addr6->replace (this->default_addr_.get_addr_size(),
+                      this->default_addr_.get_addr_size(),
+                      (unsigned char *)this->default_addr_.get_addr());
+    }
+  else
+    {
+      addr6->length(mapping_entry->int_id_.get_addr_size());
+      addr6->replace (mapping_entry->int_id_.get_addr_size(),
+                      mapping_entry->int_id_.get_addr_size(),
+                      (unsigned char *)mapping_entry->int_id_.get_addr());
+    }
+}
